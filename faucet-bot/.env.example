# Configuración del Bot de Faucets

# Entorno
NODE_ENV=production

# Binance API
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_SECRET_KEY=tu_secret_key_aqui
BINANCE_WALLET_ADDRESS=tu_direccion_btc_aqui

# FreeBitcoin
FREEBITCOIN_USERNAME=tu_email_aqui
FREEBITCOIN_PASSWORD=tu_password_aqui
FREEBITCOIN_WALLET=tu_direccion_btc_aqui

# FireFaucet
FIREFAUCET_USERNAME=tu_email_aqui
FIREFAUCET_PASSWORD=tu_password_aqui
FIREFAUCET_WALLET=tu_direccion_btc_aqui

# Cointiply
COINTIPLY_USERNAME=tu_email_aqui
COINTIPLY_PASSWORD=tu_password_aqui
COINTIPLY_WALLET=tu_direccion_btc_aqui

# Configuración de Scheduler
CRON_ENABLED=true
FREEBITCOIN_SCHEDULE="0 * * * *"
FIREFAUCET_SCHEDULE="*/10 * * * *"
COINTIPLY_SCHEDULE="*/10 * * * *"

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/

# Puppeteer
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=60000
